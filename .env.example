# API Configuration for Physical Devices
# Copy this file to .env and update with your local network IP address

# To find your IP address:
# Windows: Open Command Prompt and run 'ipconfig', look for "IPv4 Address" under your WiFi/Ethernet adapter
# Mac: Open Terminal and run 'ipconfig getifaddr en0' (WiFi) or 'ifconfig' (detailed)
# Linux: Open Terminal and run 'ip addr show' or 'hostname -I'

# Example: If your computer's IP is 192.168.1.100, set:
# EXPO_PUBLIC_API_HOST=192.168.1.100

# For Android Emulator, use: 10.0.2.2
# For iOS Simulator, use: localhost
# For Physical Device, use: Your computer's local network IP (e.g., 192.168.1.100)

EXPO_PUBLIC_API_HOST=10.0.2.2

# Optional: Override specific service URLs
# REACT_APP_API_BASE=http://localhost:3001/api/v1
# REACT_APP_UPLOAD_API_BASE=http://localhost:3002/api/v1
# REACT_APP_ANALYTICS_API_BASE=http://localhost:3004/api/v1
# REACT_APP_NOTIFICATION_API_BASE=http://localhost:3005/api/v1
